# LLM Configuration
# Provider: "google" (default), "openai", "anthropic"
LLM_PROVIDER=google

# Model name - leave empty for provider default
# Google: gemini-3.1-flash-lite-preview, gemini-1.5-flash, gemini-pro, etc.
# OpenAI: gpt-4o-mini, gpt-4o, gpt-3.5-turbo, etc.
# Anthropic: claude-3-haiku, claude-3-sonnet, claude-3-opus, etc.
LLM_MODEL=gemini-3.1-flash-lite-preview

# API Key (required)
# For Google: Get from https://makersuite.google.com/app/apikey
# For OpenAI: Get from https://platform.openai.com/api-keys
# For Anthropic: Get from https://console.anthropic.com/settings/keys
LLM_API_KEY=your_api_key_here

# Legacy fallback (still supported for backward compatibility)
# GOOGLE_API_KEY=your_key_here

# Optional parameters
LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=4096
