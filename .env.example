# Mistral LLM configuration (required)
# Get an API key at https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional: override the Mistral model (defaults to mistral-large-latest)
# LLM_MODEL=mistral-large-latest

# Optional
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=4096
